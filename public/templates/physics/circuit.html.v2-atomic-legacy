<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>电路串并联</title>
<link rel="stylesheet" href="/templates/_shared/ui-core.css">
<style>
  .circuit-canvas-wrapper {
    background: #F9FAFB;
    border: 1px solid #E5E7EB;
    border-radius: 8px;
    overflow: hidden;
  }
  .circuit-canvas-wrapper canvas { max-width: 100%; height: auto; display: block; }
  .topology-btns { display: flex; gap: 8px; margin-top: 6px; }
  .topology-btns .eureka-btn { flex: 1; font-size: 12px; }
  .topology-btns .eureka-btn.active {
    background: #059669; color: #fff; border-color: #047857;
  }
</style>
</head>
<body>
<div class="eureka-root">

  <div class="eureka-grid-3">
    <div class="eureka-stat">
      <p class="eureka-stat-label">总电流 I</p>
      <p class="eureka-stat-value primary" id="stat-current">0.000 A</p>
    </div>
    <div class="eureka-stat">
      <p class="eureka-stat-label">总功率 P</p>
      <p class="eureka-stat-value success" id="stat-power">0.0 W</p>
    </div>
    <div class="eureka-stat">
      <p class="eureka-stat-label">等效电阻 R_eq</p>
      <p class="eureka-stat-value" id="stat-req">0.0 Ω</p>
    </div>
  </div>

  <div class="eureka-canvas-wrapper circuit-canvas-wrapper">
    <canvas id="canvas" width="560" height="240"></canvas>
    <div style="margin-top:8px;text-align:center;">
      <span id="status-badge" class="eureka-badge info">串联电路</span>
    </div>
  </div>

  <div class="eureka-card">
    <h3 class="eureka-card-title">参数调节</h3>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
      <div class="eureka-control">
        <div class="eureka-control-header">
          <span class="eureka-control-label">电源电压 U</span>
          <span class="eureka-control-value"><span id="v-voltage">6</span> V</span>
        </div>
        <input id="ctl-voltage" class="eureka-slider" type="range" min="1" max="24" step="0.1" value="6">
      </div>
      <div class="eureka-control">
        <div class="eureka-control-header">
          <span class="eureka-control-label">拓扑</span>
          <span class="eureka-control-value" id="v-topology">串联</span>
        </div>
        <div class="topology-btns">
          <button class="eureka-btn active" data-topo="0">串联</button>
          <button class="eureka-btn" data-topo="1">并联</button>
        </div>
      </div>
      <div class="eureka-control">
        <div class="eureka-control-header">
          <span class="eureka-control-label">电阻 R1</span>
          <span class="eureka-control-value"><span id="v-r1">10</span> Ω</span>
        </div>
        <input id="ctl-r1" class="eureka-slider" type="range" min="0.5" max="100" step="0.5" value="10">
      </div>
      <div class="eureka-control">
        <div class="eureka-control-header">
          <span class="eureka-control-label">电阻 R2</span>
          <span class="eureka-control-value"><span id="v-r2">10</span> Ω</span>
        </div>
        <input id="ctl-r2" class="eureka-slider" type="range" min="0.5" max="100" step="0.5" value="10">
      </div>
    </div>
  </div>

</div>

<script src="/templates/_shared/experiment-core.js"></script>
<script src="/templates/_shared/ui-core.js"></script>
<script src="/templates/_shared/physics-draw.js"></script>
<script>
  'use strict';

  const TEMPLATE_ID = 'physics/circuit';
  const ENGINE_ID = 'physics/circuit';

  if (!window.__EUREKA_UI_LOADED) {
    console.error('[circuit] L3 UI atoms failed to load');
  }

  const canvas = document.getElementById('canvas');
  const ctx = canvas.getContext('2d');
  const UI = window.EurekaUI;

  const state = {
    voltage: 6,
    r1: 10,
    r2: 10,
    topology: 0, // 0=series, 1=parallel
  };

  let lastResult = null;

  async function recompute() {
    const params = {
      voltage: state.voltage,
      r1: state.r1,
      r2: state.r2,
      topology: state.topology,
    };
    try {
      const r = await window.requestCompute(ENGINE_ID, params);
      lastResult = r;
      applyResult(r);
    } catch (err) {
      console.error('[circuit] compute failed:', err.message);
    }
  }

  function applyResult(r) {
    const v = r.values;
    UI.updateStat('stat-current', UI.formatNum(v.current, 3) + ' A', 'primary');
    UI.updateStat('stat-power',   UI.formatNum(v.power, 1)   + ' W', 'success');
    UI.updateStat('stat-req',     UI.formatNum(v.rEq, 2)     + ' Ω');
    UI.updateBadge('status-badge', v.badgeText, v.badgeKind);
    draw();
  }

  function draw() {
    if (!lastResult) return;
    const v = lastResult.values;
    const W = canvas.width, H = canvas.height;
    ctx.clearRect(0, 0, W, H);

    // Thicker wire = more current (visual proxy)
    const wireThickness = Math.min(6, 1 + Math.abs(v.current) * 2);
    const bulbGlow = Math.max(0, Math.min(1, v.bulbGlow || 0));

    // Battery (left)
    ctx.save();
    ctx.strokeStyle = '#1F2937';
    ctx.lineWidth = 2;
    ctx.strokeRect(40, H / 2 - 20, 30, 40);
    ctx.font = '11px system-ui';
    ctx.fillStyle = '#1F2937';
    ctx.fillText('U=' + UI.formatNum(v.voltage, 1) + 'V', 32, H / 2 + 40);
    ctx.restore();

    // Wires + resistors based on topology
    ctx.save();
    ctx.strokeStyle = v.current > 0 ? '#F59E0B' : '#9CA3AF';
    ctx.lineWidth = wireThickness;

    if (v.topology === 'parallel') {
      // Top horizontal wire
      ctx.beginPath();
      ctx.moveTo(70, H / 2 - 20);
      ctx.lineTo(W - 70, H / 2 - 20);
      ctx.stroke();
      // Bottom horizontal wire
      ctx.beginPath();
      ctx.moveTo(70, H / 2 + 20);
      ctx.lineTo(W - 70, H / 2 + 20);
      ctx.stroke();
      // Vertical branches
      ctx.beginPath();
      ctx.moveTo(W / 2 - 60, H / 2 - 20);
      ctx.lineTo(W / 2 - 60, H / 2 + 20);
      ctx.moveTo(W / 2 + 60, H / 2 - 20);
      ctx.lineTo(W / 2 + 60, H / 2 + 20);
      ctx.stroke();
      // R1 box
      drawResistor(ctx, W / 2 - 80, H / 2 - 10, 40, 20, 'R1=' + state.r1 + 'Ω',
        'I1=' + UI.formatNum(v.currentR1, 3) + 'A');
      // R2 box
      drawResistor(ctx, W / 2 + 40, H / 2 - 10, 40, 20, 'R2=' + state.r2 + 'Ω',
        'I2=' + UI.formatNum(v.currentR2, 3) + 'A');
    } else {
      // Series: single loop with R1 then R2
      ctx.beginPath();
      ctx.moveTo(70, H / 2 - 20);
      ctx.lineTo(W - 40, H / 2 - 20);
      ctx.lineTo(W - 40, H / 2 + 20);
      ctx.lineTo(70, H / 2 + 20);
      ctx.stroke();
      drawResistor(ctx, W / 2 - 100, H / 2 - 30, 50, 20, 'R1=' + state.r1 + 'Ω',
        'U1=' + UI.formatNum(v.voltageR1, 2) + 'V');
      drawResistor(ctx, W / 2 + 40, H / 2 - 30, 50, 20, 'R2=' + state.r2 + 'Ω',
        'U2=' + UI.formatNum(v.voltageR2, 2) + 'V');
    }
    ctx.restore();

    // Light-bulb indicator at right (brightness = power fraction)
    ctx.save();
    ctx.beginPath();
    ctx.arc(W - 25, H / 2, 14, 0, Math.PI * 2);
    const glowColor = `rgba(250, 204, 21, ${0.2 + bulbGlow * 0.8})`;
    ctx.fillStyle = glowColor;
    ctx.fill();
    ctx.strokeStyle = '#CA8A04';
    ctx.lineWidth = 2;
    ctx.stroke();
    ctx.font = '10px system-ui';
    ctx.fillStyle = '#92400E';
    ctx.fillText('灯泡', W - 34, H / 2 + 32);
    ctx.restore();
  }

  function drawResistor(ctx, x, y, w, h, label, subLabel) {
    ctx.save();
    ctx.fillStyle = '#FEF3C7';
    ctx.fillRect(x, y, w, h);
    ctx.strokeStyle = '#92400E';
    ctx.lineWidth = 1.5;
    ctx.strokeRect(x, y, w, h);
    ctx.fillStyle = '#78350F';
    ctx.font = 'bold 10px system-ui';
    ctx.textAlign = 'center';
    ctx.fillText(label, x + w / 2, y + h / 2 + 3);
    if (subLabel) {
      ctx.font = '10px system-ui';
      ctx.fillStyle = '#D97706';
      ctx.fillText(subLabel, x + w / 2, y + h + 12);
    }
    ctx.textAlign = 'left';
    ctx.restore();
  }

  // Wire up
  UI.bindExistingSliders({
    voltage: (x) => { state.voltage = x; recompute(); },
    r1:      (x) => { state.r1 = x;      recompute(); },
    r2:      (x) => { state.r2 = x;      recompute(); },
  });

  // Topology buttons
  document.querySelectorAll('button[data-topo]').forEach(btn => {
    btn.addEventListener('click', () => {
      state.topology = Number(btn.getAttribute('data-topo'));
      document.querySelectorAll('button[data-topo]').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById('v-topology').textContent =
        state.topology === 1 ? '并联' : '串联';
      recompute();
    });
  });

  window.EurekaHost.setTemplateId(TEMPLATE_ID);
  recompute().then(() => {
    window.EurekaHost.emitReady(['voltage', 'r1', 'r2', 'topology']);
  });
</script>
</body>
</html>
