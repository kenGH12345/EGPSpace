### 2. 工作流引擎 (src/workflow/engine.ts)

```diff
+// src/workflow/engine.ts
+import { WorkflowDefinition, WorkflowExecution, WorkflowStep, StepExecution, WorkflowEvent, WorkflowError, WorkflowErrorCode } from './types';
+
+export class WorkflowEngine {
+  private executions: Map<string, WorkflowExecution> = new Map();
+  private eventListeners: Map<string, Function[]> = new Map();
+
+  constructor(private storage?: WorkflowStorage) {}
+
+  async createExecution(workflow: WorkflowDefinition, initialVariables?: Record<string, any>): Promise<WorkflowExecution> {
+    const execution: WorkflowExecution = {
+      id: this.generateId(),
+      workflowId: workflow.id,
+      status: 'pending',
+      stepHistory: [],
+      variables: initialVariables || {},
+      createdAt: new Date(),
+      updatedAt: new Date()
+    };
+
+    this.executions.set(execution.id, execution);
+    
+    if (this.storage) {
+      await this.storage.saveExecution(execution);
+    }
+
+    this.emitEvent({
+      type: 'workflow_started',
+      executionId: execution.id,
+      timestamp: new Date()
+    });
+
+    return execution;
+  }
+
+  async startExecution(executionId: string): Promise<WorkflowExecution> {
+    const execution = this.executions.get(executionId);
+    if (!execution) {
+      throw this.createError(WorkflowErrorCode.EXECUTION_NOT_FOUND, `Execution ${executionId} not found`);
+    }
+
+    execution.status = 'running';
+    execution.startedAt = new Date();
+    execution.updatedAt = new Date();
+
+    const workflow = await this.getWorkflowDefinition(execution.workflowId);
+    const firstStep = workflow.steps[0];
+    
+    if (firstStep) {
+      execution.currentStep = firstStep.id;
+      await this.executeStep(execution, firstStep);
+    }
+
+    if (this.storage) {
+      await this.storage.saveExecution(execution);
+    }
+
+    return execution;
+  }
+
+  private async executeStep(execution: WorkflowExecution, step: WorkflowStep): Promise<void> {
+    const stepExecution: StepExecution = {
+      stepId: step.id,
+      status: 'running',
+      startedAt: new Date()
+    };
+
+    execution.stepHistory.push(stepExecution);
+    execution.updatedAt = new Date();
+
+    this.emitEvent({
+      type: 'step_started',
+      executionId: execution.id,
+      stepId: step.id,
+      timestamp: new Date()
+    });
+
+    try {
+      // 执行步骤逻辑
+      const result = await this.executeStepLogic(step, execution.variables);
+      
+      stepExecution.status = 'completed';
+      stepExecution.completedAt = new Date();
+      stepExecution.result = result;
+
+      // 确定下一步
+      const nextStepId = this.determineNextStep(step, result, execution.variables);
+      execution.currentStep = nextStepId;
+
+      if (nextStepId) {
+        const workflow = await this.getWorkflowDefinition(execution.workflowId);
+        const nextStep = workflow.steps.find(s => s.id === nextStepId);
+        
+        if (nextStep) {
+          await this.executeStep(execution, nextStep);
+        } else {
+          // 没有下一步，工作流完成
+          execution.status = 'completed';
+          execution.completedAt = new Date();
+        }
+      } else {
+        // 没有下一步，工作流完成
+        execution.status = 'completed';
+        execution.completedAt = new Date();
+      }
+
+      this.emitEvent({
+        type: 'step_completed',
+        executionId: execution.id,
+        stepId: step.id,
+        timestamp: new Date(),
+        data: result
+      });
+
+    } catch (error) {
+      stepExecution.status = 'failed';
+      stepExecution.completedAt = new Date();
+      stepExecution.error = error instanceof Error ? error.message : String(error);
+      
+      execution.status = 'failed';
+      execution.completedAt = new Date();
+
+      this.emitEvent({
+        type: 'error',
+        executionId: execution.id,
+        stepId: step.id,
+        timestamp: new Date(),
+        data: { error: stepExecution.error }
+      });
+    }
+
+    if (this.storage) {
+      await this.storage.saveExecution(execution);
+    }
+  }
+
+  private async executeStepLogic(step: WorkflowStep, variables: Record<string, any>): Promise<any> {
+    // 这里应该调用实际的组件执行逻辑
+    // 目前返回模拟结果
+    return { 
+      stepId: step.id,
+      variables: { ...variables, [`step_${step.id}_result`]: 'completed' }
+    };
+  }
+
+  private determineNextStep(step: WorkflowStep, result: any, variables: Record<string, any>): string | null {
+    if (step.type === 'condition' && step.conditions) {
+      // 条件分支逻辑
+      for (const condition of step.conditions) {
+        if (this.evaluateCondition(condition.condition, variables)) {
+          return condition.nextStep;
+        }
+      }
+    }
+    
+    return typeof step.next === 'string' ? step.next : null;
+  }
+
+  private evaluateCondition(condition: string, variables: Record<string, any>): boolean {
+    // 简单的条件评估逻辑
+    // 实际实现应该使用安全的表达式评估器
+    try {
+      const expr = condition.replace(/\$\{([^}]+)\}/g, (_, key) => {
+        return JSON.stringify(variables[key] || '');
+      });
+      
+      // 使用Function构造函数进行安全评估
+      return new Function(`return ${expr}`)();
+    } catch {
+      return false;
+    }
+  }
+
+  async getExecution(executionId: string): Promise<WorkflowExecution | null> {
+    const execution = this.executions.get(executionId);
+    if (execution && this.storage) {
+      return await this.storage.getExecution(executionId);
+    }
+    return execution || null;
+  }
+
+  onEvent(eventType: string, listener: (event: WorkflowEvent) => void): void {
+    if (!this.eventListeners.has(eventType)) {
+      this.eventListeners.set(eventType, []);
+    }
+    this.eventListeners.get(eventType)!.push(listener);
+  }
+
+  private emitEvent(event: WorkflowEvent): void {
+    const listeners = this.eventListeners.get(event.type) || [];
+    listeners.forEach(listener => listener(event));
+  }
+
+  private async getWorkflowDefinition(workflowId: string): Promise<WorkflowDefinition> {
+    // 从存储或缓存获取工作流定义
+    if (this.storage) {
+      return await this.storage.getWorkflowDefinition(workflowId);
+    }
+    
+    // 模拟返回
+    return {
+      id: workflowId,
+      name: 'Test Workflow',
+      version: '1.0.0',
+      steps: []
+    };
+  }
+
+  private generateId(): string {
+    return `exec_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`;
+  }
+
+  private createError(code: WorkflowErrorCode, message: string): WorkflowError {
+    const error = new Error(message) as WorkflowError;
+    error.code = code;
+    return error;
+  }
+}
```

### 3. 工作流验证器 (src/workflow/validator.ts)

```diff
+// src/workflow/validator.ts
+import { WorkflowDefinition, WorkflowStep, WorkflowError, WorkflowErrorCode } from './types';
+
+export class WorkflowValidator {
+  static validateDefinition(definition: WorkflowDefinition): void {
+    const errors: string[] = [];
+
+    // 基本验证
+    if (!definition.id) {
+      errors.push('Workflow ID is required');
+    }
+    
+    if (!definition.name) {
+      errors.push('Workflow name is required');
+    }
+    
+    if (!definition.version) {
+      errors.push('Workflow version is required');
+    }
+    
+    if (!definition.steps || definition.steps.length === 0) {
+      errors.push('Workflow must have at least one step');
+    }
+
+    // 步骤验证
+    definition.steps.forEach((step, index) => {
+      const stepErrors = this.validateStep(step, index, definition.steps);
+      errors.push(...stepErrors);
+    });
+
+    // 循环检测
+    const cycleErrors = this.detectCycles(definition.steps);
+    errors.push(...cycleErrors);
+
+    if (errors.length > 0) {
+      const error = new Error(`Workflow validation failed: ${errors.join(', ')}`) as WorkflowError;
+      error.code = WorkflowErrorCode.VALIDATION_FAILED;
+      throw error;
+    }
+  }
+
+  private static validateStep(step: WorkflowStep, index: number, allSteps: WorkflowStep[]): string[] {
+    const errors: string[] = [];
+
+    if (!step.id) {
+      errors.push(`Step ${index + 1}: ID is required`);
+    }
+    
+    if (!step.name) {
+      errors.push(`Step ${index + 1}: Name is required`);
+    }
+    
+    if (!step.type) {
+      errors.push(`Step ${index + 1}: Type is required`);
+    }
+    
+    if (!step.component) {
+      errors.push(`Step ${index + 1}: Component is required`);
+    }
+
+    // 验证下一步引用
+    if (step.next) {
+      if (typeof step.next === 'string') {
+        if (!allSteps.some(s => s.id === step.next)) {
+          errors.push(`Step ${step.id}: Next step '${step.next}' not found`);
+        }
+      } else if (Array.isArray(step.next)) {
+        step.next.forEach(nextId => {
+          if (!allSteps.some(s => s.id === nextId)) {
+            errors.push(`Step ${step.id}: Next step '${nextId}' not found`);
+          }
+        });
+      }
+    }
+
+    // 条件步骤验证
+    if (step.type === 'condition' && (!step.conditions || step.conditions.length === 0)) {
+      errors.push(`Step ${step.id}: Condition steps must have at least one condition`);
+    }
+
+    return errors;
+  }
+
+  private static detectCycles(steps: WorkflowStep[]): string[] {
+    const errors: string[] = [];
+    const visited: Set<string> = new Set();
+    const visiting: Set<string> = new Set();
+
+    const dfs = (stepId: string, path: string[]): boolean => {
+      if (visiting.has(stepId)) {
+        errors.push(`Cycle detected: ${[...path, stepId].join(' -> ')}`);
+        return true;
+      }
+      
+      if (visited.has(stepId)) {
+        return false;
+      }
+
+      visiting.add(stepId);
+      path.push(stepId);
+
+      const step = steps.find(s => s.id === stepId);
+      if (step && step.next) {
+        const nextSteps = typeof step.next === 'string' ? [step.next] : step.next;
+        
+        for (const nextId of nextSteps) {
+          if (dfs(nextId, path)) {
+            return true;
+          }
+        }
+      }
+
+      visiting.delete(stepId);
+      path.pop();
+      visited.add(stepId);
+      
+      return false;
+    };
+
+    steps.forEach(step => {
+      if (!visited.has(step.id)) {
+        dfs(step.id, []);
+      }
+    });
+
+    return errors;
+  }
+}
```

### 4. 数据存储接口 (src/workflow/storage.ts)

```diff
+// src/workflow/storage.ts
+import { WorkflowDefinition, WorkflowExecution } from './types';
+
+export interface WorkflowStorage {
+  saveWorkflowDefinition(definition: WorkflowDefinition): Promise<void>;
+  getWorkflowDefinition(id: string): Promise<WorkflowDefinition | null>;
+  saveExecution(execution: WorkflowExecution): Promise<void>;
+  getExecution(id: string): Promise<WorkflowExecution | null>;
+  listExecutions(workflowId?: string, status?: string): Promise<WorkflowExecution[]>;
+}
+
+export class InMemoryStorage implements WorkflowStorage {
+  private definitions: Map<string, WorkflowDefinition> = new Map();
+  private executions: Map<string, WorkflowExecution> = new Map();
+
+  async saveWorkflowDefinition(definition: WorkflowDefinition): Promise<void> {
+    this.definitions.set(definition.id, definition);
+  }
+
+  async getWorkflowDefinition(id: string): Promise<WorkflowDefinition | null> {
+    return this.definitions.get(id) || null;
+  }
+
+  async saveExecution(execution: WorkflowExecution): Promise<void> {
+    this.executions.set(execution.id, execution);
+  }
+
+  async getExecution(id: string): Promise<WorkflowExecution | null> {
+    return this.executions.get(id) || null;
+  }
+
+  async listExecutions(workflowId?: string, status?: string): Promise<WorkflowExecution[]> {
+    let executions = Array.from(this.executions.values());
+    
+    if (workflowId) {
+      executions = executions.filter(e => e.workflowId === workflowId);
+    }
+    
+    if (status) {
+      executions = executions.filter(e => e.status === status);
+    }
+    
+    return executions.sort((a, b) => b.createdAt.getTime() - a.createdAt.getTime());
+  }
+}
```

